{
  "hooks": {
    "SessionStart":       [{ "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event SessionStart" }] }],
    "UserPromptSubmit":   [{ "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event UserPromptSubmit" }] }],
    "PreToolUse":         [{ "matcher": "*", "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event PreToolUse" }] }],
    "PostToolUse":        [{ "matcher": "*", "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event PostToolUse" }] }],
    "PostToolUseFailure": [{ "matcher": "*", "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event PostToolUseFailure" }] }],
    "PermissionRequest":  [{ "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event PermissionRequest" }] }],
    "PermissionDenied":   [{ "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event PermissionDenied" }] }],
    "Stop":               [{ "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event Stop" }] }],
    "SubagentStop":       [{ "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event SubagentStop" }] }],
    "PreCompact":         [{ "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event PreCompact" }] }],
    "SessionEnd":         [{ "hooks": [{ "type": "command", "command": "python3 /path/to/weave-agent-adapter/weave_agent_adapter/hook.py --event SessionEnd" }] }]
  }
}
